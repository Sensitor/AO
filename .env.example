# Copy to .env and adjust before running.
DATABASE_URL=postgresql+psycopg://aocopilot:aocopilot@db:5432/aocopilot
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Frontend origin allowed by CORS (Next.js dev server)
FRONTEND_ORIGIN=http://localhost:3000

# Ports hôte exposés (à changer s'ils sont déjà pris ; sans effet sur le réseau interne).
# API_PORT=8000
# DB_PORT=5432

# --- Sprint 1: storage S3 (MinIO en dev) ---
# Pour Cloudflare R2 en prod: S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=aocopilot
S3_SECRET_KEY=aocopilot
S3_BUCKET=ao-documents
S3_USE_PATH_STYLE=true

# --- Sprint 1: embeddings OpenAI (obligatoire pour l'ingestion) ---
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- Sprint 1: chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- Sprint 2/3/4: LLM ---
LLM_MODEL=gpt-4o-mini

# --- Sprint 5: facturation Stripe (vide => facturation désactivée, tout passe) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
BILLING_SUCCESS_URL=http://localhost:3000/billing/success
BILLING_CANCEL_URL=http://localhost:3000/billing/cancel
